# SwitchAI Environment Configuration
# Copy this file to .env and fill in your values
# cp .env.example .env

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000
ROOM_SECRET=change-this-to-a-random-string

# ─── AI Model API Keys ────────────────────────────────────────────────────────
# Add only the keys you have. Missing keys gracefully disable that model.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_GEMINI_API_KEY=
MISTRAL_API_KEY=

# ─── Model Aliases ────────────────────────────────────────────────────────────
# Optional — defaults shown
CLAUDE_MODEL=claude-opus-4-6
OPENAI_MODEL=gpt-4o
GEMINI_MODEL=gemini-1.5-pro
MISTRAL_MODEL=mistral-large-latest

# ─── Context Window ───────────────────────────────────────────────────────────
# Number of messages from history.md included in each model call
HISTORY_CONTEXT_LINES=50

# ─── File Uploads ─────────────────────────────────────────────────────────────
MAX_FILE_SIZE_MB=10
