# SwitchAI Environment Configuration
# Copy this file to .env and fill in your values
# cp .env.example .env

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000
ALLOWED_ORIGINS=   # Comma-separated origins for Socket.io CORS (e.g. http://192.168.1.10:3000). Leave blank for same-origin only.
ROOM_SECRET=change-this-to-a-random-string   # Required to create new rooms — leave blank to disable

# ─── AI Model API Keys ────────────────────────────────────────────────────────
# Add only the keys you have. Missing keys gracefully disable that model.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_GEMINI_API_KEY=
MISTRAL_API_KEY=

# ─── Model Aliases ────────────────────────────────────────────────────────────
# Optional — defaults shown
CLAUDE_MODEL=claude-opus-4-6
OPENAI_MODEL=gpt-4o
GEMINI_MODEL=gemini-1.5-pro
MISTRAL_MODEL=mistral-large-latest

# ─── Context Window ───────────────────────────────────────────────────────────
# Number of messages from history.md included in each model call
HISTORY_CONTEXT_LINES=50

# ─── Web Search ───────────────────────────────────────────────────────────────\n# Enables +web flag in messages (e.g. "@claude +web latest AI news")\n# Get a free key at https://app.tavily.com (2000 queries/month free)\nTAVILY_API_KEY=\n\n# ─── File Uploads ─────────────────────────────────────────────────────────────
MAX_FILE_SIZE_MB=10

# ─── Context & Token Limits ───────────────────────────────────────────────────
MAX_CONTEXT_TOKENS=8000          # max history tokens sent per request
MAX_RECENT_MESSAGES=30           # max message blocks pulled from history
MAX_CONTEXT_CHARS=32000          # max chars from context.md
MAX_FILE_CONTEXT_CHARS=8000      # max chars from file attachments
MAX_OUTPUT_TOKENS_DEFAULT=1024   # normal replies
MAX_OUTPUT_TOKENS_SHORT_REPLY=256  # trivial/short prompts
MAX_OUTPUT_TOKENS_LONG_REPLY=4096  # extended mode (future)
LOW_CONTEXT_MESSAGE_CHAR_THRESHOLD=120  # prompts under this + trivial → minimal mode
HARD_REQUEST_TOKEN_CEILING=12000  # absolute max before request is rejected
ENABLE_TOKEN_DEBUG=false          # log context decisions to server console
